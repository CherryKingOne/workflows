{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "WeiMeng",
  "version": "0.0.2.1",
  "identifier": "com.WeiMeng.workflows",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "WeiMeng",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/CherryKingOne/workflows/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY1Q0YxNEExNkVFNjU5NEMKUldSTVdlWnVvUlRQOWFadkdyTzJLb2tYUHpPakJvcXNTa3d5bW9HQUF2UEdtdG9Wc3ZOZ1dCc3AK"
    }
  }
}
